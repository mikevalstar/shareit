PORT=3213
# Public base URL shown in the UI (e.g. https://share.example.com). No trailing slash.
PUBLIC_URL=http://localhost:3213
DB_PATH=./data/shareit.db
UPLOAD_DIR=./uploads
# Generate with: bun run hash-password '<your-password>'
# IMPORTANT: every $ in the hash must be backslash-escaped as \$ —
# Bun's .env loader expands $VAR refs even inside quotes.
# The hash-password script prints a paste-ready line for you.
ADMIN_PASSWORD_HASH=
# Optional API key for programmatic access to /admin/* endpoints.
# Send as `X-API-Key: <value>` header; bypasses session cookie auth when set.
# Generate with: openssl rand -hex 24
ADMIN_API_KEY=
# urlmeta.org credentials, used to fetch link previews when creating shortlinks.
# Format: `accountID:secret` (we base64-encode it) OR a pre-encoded base64 string.
# Sent to urlmeta as `Authorization: Basic <encoded>`.
URLMETA_BEARER=
NODE_ENV=development
